OPENROUTER_API_KEY=your_openrouter_api_key_here
PORT=3001
# NODE_ENV=production
# Optional: max wait for OpenRouter (ms), default 120000, min 10000, max 300000
# OPENROUTER_TIMEOUT_MS=120000
# Allowed browser origins (comma-separated). Default: http://localhost:3000
# CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:3000
# Referer sent to OpenRouter (first CORS origin is used if unset)
# OPENROUTER_REFERER=https://your-frontend.vercel.app
# Behind a reverse proxy (Render, Fly, nginx): set to 1
# TRUST_PROXY=1
# Optional: comma-separated model ids (see https://openrouter.ai/models?pricing=free). Defaults: Llama 3.3 70B, Llama 3.2 3B, Mistral 7B, then openrouter/free
# OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,openrouter/free
# If you see 404 "No endpoints found" for a name, the slug changed — pick a current :free id from the models page. For some accounts, also check OpenRouter Settings → Privacy (free tier).
# Optional: set to 1 only if your models support it (can cause "Provider returned error" on many free models)
# OPENROUTER_USE_JSON_MODE=0
# Optional: 1 to enable response-healing plugin (JSON repair) on OpenRouter
# OPENROUTER_USE_HEALING=0
